                },
                {
                  "type": "text",
                  "id": "l4Eao",
                  "name": "a1",
                  "fill": "$foreground-secondary",
                  "textGrowth": "fixed-width",
                  "width": 700,
                  "content": "We provide support during standard business hours, Monday through Friday. For emergency situations, we evaluate requests on a case-by-case basis to ensure critical issues are addressed promptly.",
