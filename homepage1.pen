              "children": [
                {
                  "type": "text",
                  "id": "SiWOq",
                  "name": "q2",
                  "fill": "$foreground-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "DO YOU OFFER REMOTE AND ON-SITE HELP?",
                  "fontFamily": "Anton",
                  "fontSize": 36
                },
                {
                  "type": "text",
                  "id": "flQTl",
                  "name": "a2",
                  "fill": "$foreground-secondary",
                  "textGrowth": "fixed-width",
                  "width": 700,
                  "content": "Yes. We offer remote assistance via phone, email, and remote desktop tools for quick resolution. When the situation calls for it, we also provide on-site support to handle more hands-on requirements.",
                  "lineHeight": 1.6,
                  "fontFamily": "Geist",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
