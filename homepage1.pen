                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "HOW QUICKLY CAN I EXPECT A RESPONSE?",
                  "fontFamily": "Anton",
                  "fontSize": 36
                },
                {
                  "type": "text",
                  "id": "dZUfU",
